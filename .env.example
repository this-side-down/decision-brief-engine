# Copy to `.env.local` for local Ollama inference.
#
# VITE_OLLAMA_TIMEOUT_MS=120000
#
# Windows local dev usually uses http://127.0.0.1:11434 for VITE_OLLAMA_HOST.
# Devcontainer/container users may need http://host.docker.internal:11434.

VITE_GENERATION_MODE=mock
VITE_OLLAMA_BASE_URL=/ollama
VITE_OLLAMA_MODEL=qwen3:4b
VITE_OLLAMA_HOST=http://127.0.0.1:11434

# Experimental browser WebGPU inference (hidden in public builds unless enabled):
# VITE_ENABLE_WEBGPU_INFERENCE=false
#
# Optional browser inference overrides for local testing:
# VITE_WEBGPU_MODEL_ID=Qwen2.5-1.5B-Instruct-q4f16_1-MLC
# VITE_WEBGPU_TIMEOUT_MS=120000
